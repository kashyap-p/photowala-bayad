# ── Local development (file-based SQLite) ──────────────────────────────
# The path is resolved relative to the prisma/ directory.
DATABASE_URL="file:../db/custom.db"

# ── Production (Turso / libSQL) ────────────────────────────────────────
# Create a free database at https://turso.tech, then run:
#   turso db create photowala-bayad
#   turso db url photowala-bayad     → libsql://… .turso.io
#   turso db tokens create photowala-bayad
#
# Paste the URL and token below on Vercel (Project → Settings → Environment
# Variables). Leave them commented for local dev.
#
# DATABASE_URL="libsql://photowala-bayad-xxxxxx.turso.io"
# DATABASE_AUTH_TOKEN="eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
